        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    %% Relationships\n    Users ||--|| Candidates : \&quot;has\&quot;\n    Users ||--|| Recruiters : \&quot;acts as\&quot;\n    Companies ||--o{ Recruiters : \&quot;employs\&quot;\n    Companies ||--o{ Jobs : \&quot;posts\&quot;\n    Recruiters ||--o{ Jobs : \&quot;manages\&quot;\n    Candidates ||--o{ Resumes : \&quot;uploads\&quot;\n    Candidates ||--o{ Applications : \&quot;submits\&quot;\n    Jobs ||--o{ Applications : \&quot;receives\&quot;\n    Applications ||--o{ Interviews : \&quot;schedules\&quot;\n    Users ||--o{ Notifications : \&quot;receives\&quot;\n    Candidates ||--o{ AI_Recommendations : \&quot;gets\&quot;\n    Jobs ||--o{ AI_Recommendations : \&quot;generates\&quot;\n\n    %% Entities\n    Users {\n        int id PK\n        string email\n        string password_hash\n        boolean is_verified\n        boolean is_active\n        datetime created_at\n        datetime updated_at\n    }\n\n    Candidates {\n        int id PK\n        int user_id FK\n        string first_name\n        string last_name\n        string phone\n        string city\n        string country\n        int years_of_experience\n        float current_ctc\n        float expected_ctc\n    }\n\n    Recruiters {\n        int id PK\n        int user_id FK\n        int company_id FK\n        string designation\n    }\n\n    Companies {\n        int id PK\n        string name\n        string website\n        string industry\n        string description\n        int size\n    }\n\n    Jobs {\n        int id PK\n        int company_id FK\n        int recruiter_id FK\n        string title\n        string description\n        string location\n        string employment_type\n        int experience_required\n        float salary_min\n        float salary_max\n        string status\n        datetime application_deadline\n        datetime created_at\n    }\n\n    Applications {\n        int id PK\n        int candidate_id FK\n        int job_id FK\n        int resume_id FK\n        string status\n        datetime applied_at\n    }\n\n    Interviews {\n        int id PK\n        int application_id FK\n        string interview_type\n        datetime scheduled_at\n        string meeting_link\n        string status\n    }\n\n    Notifications {\n        int id PK\n        int user_id FK\n        string title\n        string message\n        boolean is_read\n        datetime created_at\n    }\n\n    Resumes {\n        int id PK\n        int candidate_id FK\n        string file_url\n        string parsed_text\n        int ats_score\n        int resume_score\n        datetime created_at\n    }\n\n    AI_Recommendations {\n        int id PK\n        int candidate_id FK\n        int job_id FK\n        float match_score\n        string recommendation_reason\n        string missing_skills\n        string status\n    }&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="SulEWBRpL6SaSJrRkNhJ-22">
